---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Артур Фаттахов — ветеринарный врач и исследователь';
const description = 'Артур Фаттахов — ветеринарный врач, исследователь и предприниматель. Развивает ветеринарную помощь на дому для собак и кошек с применением ИИ.';
---

<BaseLayout title={title} description={description} lang="ru" canonicalPath="/ru/">
  <section class="hero">
    <p class="eyebrow">Ветеринария · Исследования · Технологии</p>
    <h1>Артур Фаттахов</h1>
    <p class="lead">
      Ветеринарный врач, исследователь и предприниматель. Развиваю доступную помощь
      собакам и кошкам на дому с применением искусственного интеллекта.
    </p>
  </section>
</BaseLayout>
