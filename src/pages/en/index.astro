---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Artur Fattakhov — Veterinary Doctor and Researcher';
const description = 'Artur Fattakhov is a veterinary doctor, researcher, and entrepreneur focused on AI-enabled home veterinary care for dogs and cats.';
---

<BaseLayout title={title} description={description} lang="en" canonicalPath="/en/">
  <section class="hero">
    <p class="eyebrow">Veterinary medicine · Research · Technology</p>
    <h1>Artur Fattakhov</h1>
    <p class="lead">
      Veterinary doctor, researcher, and entrepreneur building accessible,
      AI-enabled home veterinary care for dogs and cats.
    </p>
  </section>
</BaseLayout>
