---
import { getCollection } from 'astro:content';
import { collectionPageContent } from '../../../data/pages';
import { languages, localizedPath, type Language } from '../../../i18n/config';
import PageLayout from '../../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = collectionPageContent.publications[lang];
const entries = (await getCollection('publications', ({ data }) => data.lang === lang))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const statusLabels = {
  ru: { published: 'Опубликовано', 'working-paper': 'Рабочий материал', 'in-preparation': 'Готовится' },
  en: { published: 'Published', 'working-paper': 'Working paper', 'in-preparation': 'In preparation' },
};
---

<PageLayout {...content} lang={lang} canonicalPath={localizedPath(lang, 'publications')}>
  <ol class="entry-list">
    {entries.map((entry) => (
      <li>
        <article>
          <p class="entry-meta">{entry.data.date.getFullYear()} · {statusLabels[lang][entry.data.status]}</p>
          <h2>{entry.data.externalUrl ? <a href={entry.data.externalUrl}>{entry.data.title}</a> : entry.data.title}</h2>
          <p>{entry.data.description}</p>
          <p class="entry-authors">{entry.data.authors.join(', ')}</p>
        </article>
      </li>
    ))}
  </ol>
</PageLayout>
