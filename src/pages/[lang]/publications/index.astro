---
import PublicationsPageContent from '../../../components/PublicationsPageContent.astro';
import { collectionPageContent } from '../../../data/pages';
import { publicationPath, publicationRecords } from '../../../data/publication-records';
import { languages, localizedPath, type Language } from '../../../i18n/config';
import PageLayout from '../../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = collectionPageContent.publications[lang];
const schemaItems = publicationRecords.map((record) => ({
  name: record.title[lang],
  url: publicationPath(lang, record.slug),
}));
---

<PageLayout
  {...content}
  lang={lang}
  canonicalPath={localizedPath(lang, 'publications')}
  schemaType="CollectionPage"
  schemaItems={schemaItems}
  searchable
  searchType={lang === 'ru' ? 'Публикации' : 'Publications'}
>
  <PublicationsPageContent lang={lang} />
</PageLayout>
