---
import AboutPageContent from '../../components/AboutPageContent.astro';
import ContactPageContent from '../../components/ContactPageContent.astro';
import CvPageContent from '../../components/CvPageContent.astro';
import MediaPageContent from '../../components/MediaPageContent.astro';
import NowPageContent from '../../components/NowPageContent.astro';
import ProfilesPageContent from '../../components/ProfilesPageContent.astro';
import ResearchPageContent from '../../components/ResearchPageContent.astro';
import UsesPageContent from '../../components/UsesPageContent.astro';
import { pageContent, type StandardPageSlug } from '../../data/pages';
import { languages, localizedPath, type Language } from '../../i18n/config';
import PageLayout from '../../layouts/PageLayout.astro';

export function getStaticPaths() {
  const pages: StandardPageSlug[] = ['about', 'research', 'media', 'contact', 'cv', 'profiles', 'uses', 'now'];
  return languages.flatMap((lang) =>
    pages.map((page) => ({ params: { lang, page }, props: { lang, page } })),
  );
}

interface Props {
  lang: Language;
  page: StandardPageSlug;
}

const { lang, page } = Astro.props;
const content = pageContent[lang][page];
---

<PageLayout
  title={content.title}
  description={content.description}
  lang={lang}
  canonicalPath={localizedPath(lang, page)}
>
  {page === 'about' && <AboutPageContent lang={lang} />}
  {page === 'research' && <ResearchPageContent lang={lang} />}
  {page === 'profiles' && <ProfilesPageContent lang={lang} />}
  {page === 'contact' && <ContactPageContent lang={lang} />}
  {page === 'media' && <MediaPageContent lang={lang} />}
  {page === 'cv' && <CvPageContent lang={lang} />}
  {page === 'uses' && <UsesPageContent lang={lang} />}
  {page === 'now' && <NowPageContent lang={lang} />}
</PageLayout>
