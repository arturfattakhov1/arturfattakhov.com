---
import { getCollection } from 'astro:content';
import AboutPageContent from '../../components/AboutPageContent.astro';
import ContactPageContent from '../../components/ContactPageContent.astro';
import ConsultationPageContent from '../../components/ConsultationPageContent.astro';
import KnowledgePageContent from '../../components/KnowledgePageContent.astro';
import LegalPageContent from '../../components/LegalPageContent.astro';
import MediaPageContent from '../../components/MediaPageContent.astro';
import ProfilesPageContent from '../../components/ProfilesPageContent.astro';
import PracticePageContent from '../../components/PracticePageContent.astro';
import ResearchPageContent from '../../components/ResearchPageContent.astro';
import SearchPageContent from '../../components/SearchPageContent.astro';
import { pageContent, type StandardPageSlug } from '../../data/pages';
import type { LegalPageSlug } from '../../data/legal';
import { identity } from '../../data/identity';
import type { PageSchemaType, SchemaListItem } from '../../data/structured-data';
import { languages, localizedPath, type Language } from '../../i18n/config';
import PageLayout from '../../layouts/PageLayout.astro';

export function getStaticPaths() {
  const pages: StandardPageSlug[] = ['about', 'practice', 'research', 'media', 'contact', 'consultation', 'profiles', 'knowledge', 'search', 'privacy', 'terms', 'disclaimer'];
  return languages.flatMap((lang) =>
    pages.map((page) => ({ params: { lang, page }, props: { lang, page } })),
  );
}

interface Props {
  lang: Language;
  page: StandardPageSlug;
}

const { lang, page } = Astro.props;
const content = pageContent[lang][page];
const pageSchemaTypes: Partial<Record<StandardPageSlug, PageSchemaType>> = {
  practice: 'WebPage',
  research: 'AboutPage',
  profiles: 'CollectionPage',
  contact: 'ContactPage',
  consultation: 'WebPage',
  knowledge: 'CollectionPage',
};
const schemaType = pageSchemaTypes[page];
const searchablePages = new Set<StandardPageSlug>(['about', 'practice', 'research', 'media', 'profiles', 'knowledge', 'consultation']);
const searchTypeLabels: Partial<Record<StandardPageSlug, Record<Language, string>>> = {
  about: { ru: 'Профессиональный профиль', en: 'Professional profile' },
  practice: { ru: 'Ветеринарная практика', en: 'Veterinary practice' },
  research: { ru: 'Исследования', en: 'Research' },
  media: { ru: 'Медиа', en: 'Media' },
  profiles: { ru: 'Профессиональные профили', en: 'Professional profiles' },
  knowledge: { ru: 'База знаний', en: 'Knowledge' },
  consultation: { ru: 'Онлайн-консультация', en: 'Online consultation' },
};
let schemaItems: SchemaListItem[] | undefined;
const knowledgeArticles = page === 'knowledge'
  ? (await getCollection('knowledge', ({ data }) => data.lang === lang && data.status === 'published')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  : [];

if (page === 'profiles') {
  schemaItems = identity.profiles.map((profile) => ({ name: profile.name, url: profile.url }));
} else if (page === 'knowledge') {
  schemaItems = knowledgeArticles.map((article) => ({
    name: article.data.title,
    url: localizedPath(lang, `knowledge/${article.data.routeSlug}`),
  }));
}
---

<PageLayout
  title={content.title}
  description={content.description}
  lang={lang}
  canonicalPath={localizedPath(lang, page)}
  type={page === 'about' ? 'profile' : 'website'}
  schemaType={schemaType}
  schemaItems={schemaItems}
  professionalService={page === 'practice'}
  showVerifiedProfiles={page !== 'contact'}
  searchable={searchablePages.has(page)}
  searchType={searchTypeLabels[page]?.[lang]}
>
  {page === 'about' && <AboutPageContent lang={lang} />}
  {page === 'practice' && <PracticePageContent lang={lang} />}
  {page === 'research' && <ResearchPageContent lang={lang} />}
  {page === 'profiles' && <ProfilesPageContent lang={lang} />}
  {page === 'contact' && <ContactPageContent lang={lang} />}
  {page === 'consultation' && <ConsultationPageContent lang={lang} />}
  {page === 'media' && <MediaPageContent lang={lang} />}
  {page === 'knowledge' && <KnowledgePageContent lang={lang} articles={knowledgeArticles} />}
  {page === 'search' && <SearchPageContent lang={lang} />}
  {(['privacy', 'terms', 'disclaimer'] as StandardPageSlug[]).includes(page) && (
    <LegalPageContent lang={lang} page={page as LegalPageSlug} />
  )}
</PageLayout>
