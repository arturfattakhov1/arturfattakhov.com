---
import HomeSections from '../../components/HomeSections.astro';
import { homeContent } from '../../data/pages';
import { languages, localizedPath, type Language } from '../../i18n/config';
import PageLayout from '../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = homeContent[lang];
---

<PageLayout
  title={content.title}
  description={content.description}
  lang={lang}
  canonicalPath={localizedPath(lang)}
  showBreadcrumbs={false}
>
  <HomeSections lang={lang} />
</PageLayout>
