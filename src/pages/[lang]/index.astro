---
import { Image } from 'astro:assets';
import portrait from '../../assets/images/artur-fattakhov-homepage.jpg';
import Button from '../../components/Button.astro';
import Container from '../../components/Container.astro';
import HomeSections from '../../components/HomeSections.astro';
import homeMaterials from '../../data/cms/home-materials.json';
import { homePageCopy } from '../../data/home';
import { homeContent } from '../../data/pages';
import { publicationPath, publicationRecords } from '../../data/publication-records';
import { languages, localizedPath, type Language } from '../../i18n/config';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props as Props;
const content = homeContent[lang];
const copy = homePageCopy[lang];
const featuredRecords = homeMaterials.featuredPublicationSlugs.map((slug) => {
  const record = publicationRecords.find((item) => item.slug === slug);
  if (!record) throw new Error(`Missing verified homepage publication record: ${slug}`);
  return record;
});
---

<BaseLayout
  title={content.title}
  description={content.description}
  lang={lang}
  canonicalPath={localizedPath(lang)}
>
  <article class="page page--home home-page">
    <HomeSections lang={lang} helpTitle={copy.help.title}>
      <Fragment slot="hero">
        <Container class="home-hero">
          <div class="home-hero__copy">
            <p class="home-hero__role">{copy.hero.role}</p>
            <h1 id="page-title">{content.title}</h1>
            <p class="home-hero__benefit">{copy.hero.benefit}</p>
            <p class="home-hero__context">{copy.hero.context}</p>
            <div class="button-group">
              <Button href={localizedPath(lang, 'consultation')}>{copy.hero.primaryCta}</Button>
              <Button href={localizedPath(lang, 'about')} variant="secondary">{copy.hero.secondaryCta}</Button>
            </div>
          </div>
          <figure class="home-portrait">
            <Image
              src={portrait}
              alt={copy.hero.portraitAlt}
              width={240}
              height={240}
              format="webp"
              quality={86}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        </Container>
      </Fragment>

      <Fragment slot="help">
        <Container>
          <p class="home-section-lead">{copy.help.introduction}</p>
          <ul class="home-service-list" role="list">
            {copy.help.items.map((item) => (
              <li>
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </li>
            ))}
          </ul>
          <div class="home-section-actions">
            <Button href={localizedPath(lang, 'practice')} variant="secondary">{copy.help.practiceCta}</Button>
            <a class="home-text-link" href={localizedPath(lang, 'contact')}>{copy.help.contactCta}<span aria-hidden="true"> →</span></a>
          </div>
        </Container>
      </Fragment>

      <Fragment slot="profile">
        <Container>
          <p class="home-section-lead">{copy.profile.introduction}</p>
          <dl class="home-profile-grid">
            {copy.profile.items.map((item) => (
              <div>
                <dt>{item.title}</dt>
                <dd>{item.description}</dd>
              </div>
            ))}
          </dl>
          <a class="home-section-link" href={localizedPath(lang, 'about')}>{copy.profile.aboutLink}<span aria-hidden="true"> →</span></a>
          <p><a class="text-link" href={localizedPath(lang, 'cases/bsava-manual-ultrasonography')}>{copy.profile.caseStudyLink}<span aria-hidden="true"> →</span></a></p>
        </Container>
      </Fragment>

      <Fragment slot="materials">
        <Container>
          <p class="home-section-lead">{copy.materials.introduction}</p>
          <ol class="home-record-list">
            {featuredRecords.map((record) => (
              <li>
                <p class="home-record-list__type">
                  {copy.materials.recordType[record.type]}<span aria-hidden="true"> · </span>{record.year}
                </p>
                <h3><a href={publicationPath(lang, record.slug)}>{record.title[lang]}</a></h3>
                <a class="home-text-link" href={publicationPath(lang, record.slug)}>{copy.materials.openRecord}<span aria-hidden="true"> →</span></a>
              </li>
            ))}
          </ol>
          <a class="home-section-link" href={localizedPath(lang, 'publications')}>{copy.materials.allRecords}<span aria-hidden="true"> →</span></a>
        </Container>
      </Fragment>
    </HomeSections>
  </article>
</BaseLayout>
