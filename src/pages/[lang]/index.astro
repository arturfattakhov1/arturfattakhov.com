---
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
import CollectionPlaceholder from '../../components/CollectionPlaceholder.astro';
import Container from '../../components/Container.astro';
import HomeSections from '../../components/HomeSections.astro';
import { homePageCopy } from '../../data/home';
import { homeContent } from '../../data/pages';
import { languages, localizedPath, type Language } from '../../i18n/config';
import PageLayout from '../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = homeContent[lang];
const copy = homePageCopy[lang];
---

<PageLayout
  title={content.title}
  description={content.description}
  lang={lang}
  canonicalPath={localizedPath(lang)}
  showBreadcrumbs={false}
>
  <HomeSections lang={lang}>
    <Fragment slot="hero">
      <Container class="home-hero">
        <p class="home-hero__subtitle">{copy.hero.subtitle}</p>
        <div class="button-group">
          <Button href={localizedPath(lang, 'about')}>{copy.hero.primaryCta}</Button>
          <Button href={localizedPath(lang, 'contact')} variant="secondary">{copy.hero.secondaryCta}</Button>
        </div>
      </Container>
    </Fragment>

    <Fragment slot="identity">
      <Container>
        <ul class="card-grid" role="list">
          {copy.identity.map((item) => <li><Card {...item} /></li>)}
        </ul>
      </Container>
    </Fragment>

    <Fragment slot="work">
      <Container>
        <ul class="card-grid" role="list">
          {copy.work.map((item) => <li><Card {...item} /></li>)}
        </ul>
      </Container>
    </Fragment>

    <Fragment slot="research">
      <Container>
        <ul class="card-grid" role="list">
          {copy.research.map((title) => <li><Card title={title} status={copy.placeholderLabel} /></li>)}
        </ul>
      </Container>
    </Fragment>

    <Fragment slot="publications">
      <Container>
        <CollectionPlaceholder
          collection="publications"
          title={copy.publications.title}
          description={copy.publications.description}
        />
      </Container>
    </Fragment>

    <Fragment slot="projects">
      <Container>
        <ul class="card-grid card-grid--three" role="list">
          {copy.projects.map((title) => <li><Card title={title} status={copy.placeholderLabel} /></li>)}
        </ul>
      </Container>
    </Fragment>

    <Fragment slot="media">
      <Container>
        <ul class="card-grid" role="list">
          {copy.media.map((title) => <li><Card title={title} status={copy.placeholderLabel} /></li>)}
        </ul>
      </Container>
    </Fragment>

    <Fragment slot="profiles">
      <Container>
        <ul class="card-grid card-grid--profiles" role="list">
          {copy.profiles.map((title) => <li><Card title={title} status={copy.placeholderLabel} /></li>)}
        </ul>
      </Container>
    </Fragment>

    <Fragment slot="contact">
      <Container class="contact-panel">
        <p>{copy.contact.description}</p>
        <Button href={localizedPath(lang, 'contact')}>{copy.contact.cta}</Button>
      </Container>
    </Fragment>
  </HomeSections>
</PageLayout>
