---
import { getCollection } from 'astro:content';
import BlogPageContent from '../../../components/BlogPageContent.astro';
import { collectionPageContent } from '../../../data/pages';
import { languages, localizedPath, type Language } from '../../../i18n/config';
import PageLayout from '../../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = collectionPageContent.blog[lang];
const posts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<PageLayout {...content} lang={lang} canonicalPath={localizedPath(lang, 'blog')}>
  <BlogPageContent lang={lang} posts={posts} />
</PageLayout>
