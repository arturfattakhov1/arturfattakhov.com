---
import { getCollection } from 'astro:content';
import { collectionPageContent } from '../../../data/pages';
import { languages, localizedPath, type Language } from '../../../i18n/config';
import { ui } from '../../../i18n/ui';
import PageLayout from '../../../layouts/PageLayout.astro';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang }, props: { lang } }));
}

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const content = collectionPageContent.blog[lang];
const posts = (await getCollection('blog', ({ data }) => data.lang === lang && !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
const dateFormatter = new Intl.DateTimeFormat(lang === 'ru' ? 'ru-RU' : 'en-GB', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<PageLayout {...content} lang={lang} canonicalPath={localizedPath(lang, 'blog')}>
  {posts.length > 0 && (
    <ol class="entry-list">
      {posts.map((post) => (
        <li>
          <article>
            <time datetime={post.data.publishDate.toISOString()}>{dateFormatter.format(post.data.publishDate)}</time>
            <h2><a href={localizedPath(lang, 'blog/' + post.data.routeSlug)}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <a class="text-link" href={localizedPath(lang, 'blog/' + post.data.routeSlug)}>{ui[lang].readMore}<span aria-hidden="true"> →</span></a>
          </article>
        </li>
      ))}
    </ol>
  )}
</PageLayout>
