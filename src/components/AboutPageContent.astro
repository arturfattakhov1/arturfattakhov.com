---
import { aboutPageCopy } from '../data/about';
import { identity } from '../data/identity';
import type { Language } from '../i18n/config';
import AboutSections from './AboutSections.astro';
import Button from './Button.astro';
import CollectionPlaceholder from './CollectionPlaceholder.astro';
import Container from './Container.astro';
import KnowledgeHubNavigation from './KnowledgeHubNavigation.astro';
import LinkCard from './LinkCard.astro';
import ProfileCard from './ProfileCard.astro';
import { localizedPath } from '../i18n/config';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = aboutPageCopy[lang];
type ProfileKey = (typeof identity.profiles)[number]['key'];
const profilesByKey = new Map(identity.profiles.map((profile) => [profile.key, profile] as const));
const profileKeys: ProfileKey[] = ['orcid', 'googleScholar', 'researchGate', 'webOfScience', 'github'];
const selectedProfiles = profileKeys
  .map((key) => profilesByKey.get(key))
  .filter((profile) => profile !== undefined);
---

<AboutSections lang={lang}>
  <Fragment slot="hero">
    <Container class="about-copy about-copy--lead">
      <p>{copy.hero}</p>
    </Container>
  </Fragment>

  <Fragment slot="biography">
    <Container class="about-copy">
      {copy.biography.map((paragraph) => <p>{paragraph}</p>)}
    </Container>
  </Fragment>

  <Fragment slot="expertise">
    <Container class="about-copy">
      <p>{copy.expertiseIntroduction}</p>
      <ul>
        {copy.expertise.map((item) => <li>{item}</li>)}
      </ul>
    </Container>
  </Fragment>

  <Fragment slot="current-work">
    <Container class="about-copy">
      {copy.currentWork.map((paragraph) => <p>{paragraph}</p>)}
    </Container>
  </Fragment>

  <Fragment slot="research">
    <Container class="about-copy">
      {copy.research.map((paragraph) => <p>{paragraph}</p>)}
      <div class="button-group">
        <Button href={localizedPath(lang, 'research')}>{lang === 'ru' ? 'Исследовательские направления' : 'Research directions'}</Button>
      </div>
      <KnowledgeHubNavigation lang={lang} />
    </Container>
  </Fragment>

  <Fragment slot="projects">
    <Container>
      <CollectionPlaceholder collection="projects" {...copy.placeholders.projects} />
      <div class="button-group">
        <Button href={localizedPath(lang, 'projects')} variant="secondary">{lang === 'ru' ? 'Профессиональные проекты' : 'Professional projects'}</Button>
      </div>
    </Container>
  </Fragment>

  <Fragment slot="education">
    <Container>
      <CollectionPlaceholder collection="about-education" {...copy.placeholders.education} />
    </Container>
  </Fragment>

  <Fragment slot="profiles">
    <Container>
      <ul class="card-grid" role="list">
        {selectedProfiles.map((profile) => (
          <li><ProfileCard profile={profile} linkLabel={copy.profileLinkLabel} externalLinkLabel={copy.externalLinkLabel} /></li>
        ))}
      </ul>
      <div class="button-group">
        <Button href={localizedPath(lang, 'profiles')} variant="secondary">{copy.profileHubCta}</Button>
      </div>
    </Container>
  </Fragment>

  <Fragment slot="publications">
    <Container>
      <LinkCard
        title={copy.placeholders.publications.title}
        description={copy.placeholders.publications.description}
        href={localizedPath(lang, 'publications')}
        linkLabel={copy.publicationsCta}
      />
    </Container>
  </Fragment>

  <Fragment slot="media">
    <Container>
      <CollectionPlaceholder collection="media" {...copy.placeholders.media} />
    </Container>
  </Fragment>

  <Fragment slot="contact">
    <Container class="contact-panel">
      <p>{copy.contact.description}</p>
      <Button href={localizedPath(lang, 'contact')}>{copy.contact.cta}</Button>
    </Container>
  </Fragment>
</AboutSections>
