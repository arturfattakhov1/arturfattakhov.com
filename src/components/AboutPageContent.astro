---
import { aboutPageCopy } from '../data/about';
import { getTimelineEntries } from '../data/timeline';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import AboutSections from './AboutSections.astro';
import Button from './Button.astro';
import Container from './Container.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = aboutPageCopy[lang];
const timelineIds = ['veterinary-education', 'research-teaching-qualification', 'private-practice', 'journal-publications-2025', 'patent-2025', 'diagnostic-imaging-qualification'];
const timeline = getTimelineEntries(lang).filter((entry) => timelineIds.includes(entry.id));
---

<AboutSections lang={lang}>
  <Fragment slot="introduction">
    <Container size="reading" class="about-professional-intro">
      <ul class="about-role-list" role="list">{copy.introduction.roles.map((role) => <li>{role}</li>)}</ul>
      <p class="about-professional-intro__lead">{copy.introduction.lead}</p>
      <p>{copy.introduction.body}</p>
    </Container>
  </Fragment>
  <Fragment slot="why-veterinary-medicine"><Container size="reading"><p class="section-lead-compact">{copy.motivation.body}</p></Container></Fragment>
  <Fragment slot="clinical-practice">
    <Container size="reading"><p class="section-lead-compact">{copy.practice.body}</p><ul class="compact-evidence-list">{copy.practice.details.map((item) => <li>{item}</li>)}</ul><a class="text-link" href={localizedPath(lang, 'practice')}>{copy.links.practice}<span aria-hidden="true"> →</span></a></Container>
  </Fragment>
  <Fragment slot="diagnostic-imaging">
    <Container size="reading"><p class="section-lead-compact">{copy.imaging.body}</p><ul class="compact-evidence-list">{copy.imaging.details.map((item) => <li>{item}</li>)}</ul></Container>
  </Fragment>
  <Fragment slot="entrepreneurial-experience"><Container size="reading"><p class="section-lead-compact">{copy.entrepreneurship.body}</p></Container></Fragment>
  <Fragment slot="research-qualification">
    <Container size="reading"><p class="section-lead-compact">{copy.qualification.body}</p><ul class="compact-evidence-list">{copy.qualification.details.map((item) => <li>{item}</li>)}</ul><a class="text-link" href={localizedPath(lang, 'research')}>{copy.links.research}<span aria-hidden="true"> →</span></a></Container>
  </Fragment>
  <Fragment slot="professional-vision">
    <Container size="reading" class="about-vision"><p class="section-lead-compact">{copy.vision.body}</p><ul class="compact-evidence-list">{copy.vision.principles.map((item) => <li>{item}</li>)}</ul><Button href={localizedPath(lang, 'contact')} variant="secondary">{copy.links.contact}</Button></Container>
  </Fragment>
  <Fragment slot="professional-timeline">
    <Container size="reading">
      <p class="section-lead-compact">{copy.timeline.introduction}</p>
      <ol class="about-inline-timeline">
        {timeline.map((entry) => <li id={`about-${entry.id}`}><time datetime={entry.datetime}>{entry.period}</time><div><p>{copy.timeline.sourceLabel}</p><h3>{entry.title}</h3><span>{entry.summary}</span></div></li>)}
      </ol>
      <nav class="compact-link-row" aria-label={lang === 'ru' ? 'Связанные разделы' : 'Related sections'}><a href={localizedPath(lang, 'publications')}>{copy.links.publications}</a><a href={localizedPath(lang, 'research')}>{copy.links.research}</a></nav>
    </Container>
  </Fragment>
</AboutSections>
