---
import { identity } from '../data/identity';
import { profileGroups, profilesPageCopy, type ProfileKey } from '../data/profiles';
import type { Language } from '../i18n/config';
import Container from './Container.astro';
import ProfileCard from './ProfileCard.astro';
import ProfilesSections from './ProfilesSections.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = profilesPageCopy[lang];
const byKey = new Map(identity.profiles.map((profile) => [profile.key, profile] as const));
const select = (keys: readonly ProfileKey[]) => keys.map((key) => byKey.get(key)).filter((profile) => profile !== undefined);
---
<ProfilesSections lang={lang}>
  <Fragment slot="opening"><Container size="reading" class="profiles-compact-intro"><p>{copy.opening}</p></Container></Fragment>
  <Fragment slot="scientific"><Container><p class="profiles-group-description">{copy.groups.scientific.description}</p><ul class="profile-icon-grid" role="list">{select(profileGroups.scientific).map((profile) => <li><ProfileCard profile={profile} openLabel={copy.openLabel} externalLinkLabel={copy.externalLabel} /></li>)}</ul></Container></Fragment>
  <Fragment slot="media"><Container><p class="profiles-group-description">{copy.groups.media.description}</p><ul class="profile-icon-grid" role="list">{select(profileGroups.media).map((profile) => <li><ProfileCard profile={profile} openLabel={copy.openLabel} externalLinkLabel={copy.externalLabel} /></li>)}</ul></Container></Fragment>
  <Fragment slot="social"><Container><p class="profiles-group-description">{copy.groups.social.description}</p><ul class="profile-icon-grid" role="list">{select(profileGroups.social).map((profile) => <li><ProfileCard profile={profile} openLabel={copy.openLabel} externalLinkLabel={copy.externalLabel} /></li>)}</ul></Container></Fragment>
  <Fragment slot="technical"><Container><p class="profiles-group-description">{copy.groups.technical.description}</p><ul class="profile-icon-grid" role="list">{select(profileGroups.technical).map((profile) => <li><ProfileCard profile={profile} openLabel={copy.openLabel} externalLinkLabel={copy.externalLabel} /></li>)}</ul></Container></Fragment>
</ProfilesSections>
