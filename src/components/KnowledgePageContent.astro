---
import type { CollectionEntry } from 'astro:content';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Container from './Container.astro';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; articles: CollectionEntry<'knowledge'>[]; }
const { lang, articles } = Astro.props;
const copy = {
  ru: {
    lead: 'База знаний для владельцев животных: понятные материалы о подготовке к обращению, диагностическом контексте и границах самостоятельной интерпретации.',
    context: 'Здесь публикуются только проверенные авторские материалы. Общая информация не заменяет осмотр, диагностику или назначение лечения ветеринарным врачом.',
    title: 'Опубликованные материалы', empty: 'Опубликованных материалов пока нет. Черновики будущих тем не отображаются до редакционной и медицинской проверки.',
    action: 'Открыть материал', related: 'Полезные разделы', practice: 'Практика', contact: 'Связаться', media: 'Медиа',
  },
  en: {
    lead: 'A knowledge base for animal owners: clear material on preparing for care, diagnostic context, and the limits of self-interpretation.',
    context: 'Only reviewed authored material is published here. General information does not replace examination, diagnosis, or treatment prescribed by a veterinary clinician.',
    title: 'Published material', empty: 'No material has been published yet. Draft topics remain hidden until editorial and medical review is complete.',
    action: 'Open article', related: 'Useful sections', practice: 'Practice', contact: 'Contact', media: 'Media',
  },
} as const;
const text = copy[lang];
---

<div class="section-stack knowledge-owner" data-knowledge-index data-published-count={articles.length}>
  <PageIntro><Container size="reading" class="knowledge-owner__intro"><p class="knowledge-owner__lead">{text.lead}</p><p>{text.context}</p></Container></PageIntro>
  <PageSection id="published-material" title={text.title} density="compact">
    <Container size="reading">
      {articles.length === 0 ? <p class="knowledge-empty-state" data-knowledge-empty>{text.empty}</p> : (
        <ol class="knowledge-article-list">{articles.map((article) => <li><article><p>{article.data.category} · <time datetime={article.data.date.toISOString()}>{article.data.date.toLocaleDateString(lang === 'ru' ? 'ru-RU' : 'en-GB')}</time></p><h3><a href={localizedPath(lang, `knowledge/${article.data.routeSlug}`)}>{article.data.title}</a></h3><span>{article.data.excerpt}</span><a class="text-link" href={localizedPath(lang, `knowledge/${article.data.routeSlug}`)}>{text.action}<span aria-hidden="true"> →</span></a></article></li>)}</ol>
      )}
    </Container>
  </PageSection>
  <PageSection id="knowledge-related" title={text.related} density="compact"><Container size="reading"><nav class="compact-link-row" aria-label={text.related}><a href={localizedPath(lang, 'practice')}>{text.practice}</a><a href={localizedPath(lang, 'contact')}>{text.contact}</a><a href={localizedPath(lang, 'media')}>{text.media}</a></nav></Container></PageSection>
</div>
