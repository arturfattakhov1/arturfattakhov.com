---
import { getKnowledgePage, knowledgeRecordCount } from '../data/knowledge';
import type { Language } from '../i18n/config';
import Container from './Container.astro';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = getKnowledgePage(lang);
---

<div
  class="section-stack knowledge-sections knowledge-sections--v2"
  data-knowledge-page
  data-knowledge-theme-count={copy.themes.length}
  data-knowledge-record-count={knowledgeRecordCount}
>
  <PageIntro class="knowledge-opening">
    <Container class="knowledge-opening__copy" size="reading">
      <p class="eyebrow">{copy.opening.eyebrow}</p>
      <p class="knowledge-opening__lead">{copy.opening.lead}</p>
      <p class="knowledge-opening__context">{copy.opening.context}</p>

      <nav class="knowledge-topic-navigation" aria-label={copy.topicsLabel}>
        <ul>
          {copy.themes.map((theme) => (
            <li><a href={`#${theme.id}`}>{theme.title}</a></li>
          ))}
        </ul>
      </nav>
    </Container>
  </PageIntro>

  {copy.themes.map((theme) => (
    <PageSection id={theme.id} title={theme.title} class="knowledge-theme" density="compact">
      <div
        class="knowledge-theme__content"
        data-knowledge-theme={theme.id}
        data-knowledge-theme-record-count={theme.records.length}
      >
        <Container>
          <div class="knowledge-theme__introduction">
            <p>{theme.description}</p>
            <p class="knowledge-theme__count">{theme.countLabel}</p>
          </div>

          <nav aria-label={theme.recordsLabel}>
            <ul class="knowledge-record-list">
              {theme.records.map((record) => (
                <li
                  data-knowledge-record={record.slug}
                  data-knowledge-record-type={record.type}
                  data-knowledge-record-year={record.year}
                >
                  <a href={record.href}>
                    <span class="knowledge-record__meta">
                      <span>{record.typeLabel}</span>
                      <time datetime={String(record.year)}>{record.year}</time>
                    </span>
                    <span class="knowledge-record__title">{record.title}</span>
                    <span class="knowledge-record__arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </Container>
      </div>
    </PageSection>
  ))}

  <PageSection id="scope" title={copy.scope.title} class="knowledge-scope" density="compact">
    <Container class="knowledge-scope__copy">
      <p>{copy.scope.introduction}</p>
      <p>{copy.scope.evidence}</p>
      <a href={copy.scope.linkHref}>{copy.scope.linkLabel}<span aria-hidden="true"> →</span></a>
    </Container>
  </PageSection>

  <PageSection id="related" title={copy.related.title} class="knowledge-related-section" density="compact">
    <Container>
      <p class="knowledge-related__introduction">{copy.related.introduction}</p>
      <nav class="knowledge-related" aria-label={copy.related.label}>
        <ul>
          {copy.related.links.map((link) => (
            <li>
              <a href={link.href}>
                <span>{link.label}</span>
                <span aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </Container>
  </PageSection>
</div>
