---
interface Props {
  id: string;
  title: string;
  class?: string;
  density?: 'open' | 'editorial' | 'compact';
}

const { id, title, class: className, density = 'editorial' } = Astro.props;
const headingId = `${id}-heading`;
---

<section class:list={['page-section', `page-section--${density}`, className]} id={id} aria-labelledby={headingId}>
  <h2 id={headingId}>{title}</h2>
  <slot />
</section>
