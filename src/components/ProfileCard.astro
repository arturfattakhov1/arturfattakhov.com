---
import { identity } from '../data/identity';
type IdentityProfile = (typeof identity.profiles)[number];
interface Props { profile: IdentityProfile; openLabel: string; externalLinkLabel: string; }
const { profile, openLabel, externalLinkLabel } = Astro.props;
---
<a class="profile-icon-card" href={profile.url} target="_blank" rel="me noopener noreferrer" aria-label={`${openLabel}: ${profile.name} (${externalLinkLabel})`}>
  <img src={`/icons/profiles/${profile.key}.svg`} width="28" height="28" alt="" aria-hidden="true" loading="lazy" />
  <span>{profile.name}</span><span aria-hidden="true">↗</span>
</a>
