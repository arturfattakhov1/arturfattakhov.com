---
import { getTimelineContextLinks, getTimelineEntries, timelinePageCopy } from '../data/timeline';
import type { Language } from '../i18n/config';
import Container from './Container.astro';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = timelinePageCopy[lang];
const entries = getTimelineEntries(lang);
const contextLinks = getTimelineContextLinks(lang);
---

<div class="section-stack timeline-sections timeline-sections--v2">
  <PageIntro class="timeline-opening">
    <Container class="timeline-opening__copy" size="reading">
      <p class="eyebrow">{copy.opening.eyebrow}</p>
      <p class="timeline-opening__lead">{copy.opening.lead}</p>
      <p class="timeline-opening__context">{copy.opening.context}</p>
    </Container>
  </PageIntro>

  <PageSection id="professional-timeline" title={copy.chronologyTitle} density="open">
    <Container>
      <ol class="timeline-list">
        {entries.map((entry) => (
          <li
            id={`timeline-${entry.id}`}
            data-timeline-entry={entry.id}
            data-timeline-source={entry.source}
            data-current={entry.current ? 'true' : undefined}
          >
            <article class="timeline-entry">
              <div class="timeline-entry__aside">
                <time datetime={entry.datetime}>{entry.period}</time>
                <p>{copy.categories[entry.category]}</p>
              </div>
              <div class="timeline-entry__body">
                <h3>{entry.title}</h3>
                <p>{entry.summary}</p>
                {entry.link && (
                  <a class="timeline-entry__link" data-timeline-link={entry.id} href={entry.link.href}>
                    {entry.link.label}
                  </a>
                )}
              </div>
            </article>
          </li>
        ))}
      </ol>
    </Container>
  </PageSection>

  <PageSection id="related-records" title={copy.contextTitle} density="compact">
    <Container>
      <p class="timeline-context__intro">{copy.contextIntro}</p>
      <nav class="timeline-context" aria-label={copy.contextLabel}>
        <ul>
          {contextLinks.map((link) => (
            <li>
              <a href={link.href}>
                <span>{link.title}</span>
                <small>{link.description}</small>
                <span aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </Container>
  </PageSection>
</div>
