---
import type { Language } from '../i18n/config';
import { swapLanguage } from '../i18n/config';
import { createIdentityJsonLd, identity } from '../data/identity';

interface Props {
  title: string;
  description: string;
  lang: Language;
  canonicalPath: string;
  type?: 'profile' | 'article' | 'website';
  publishedTime?: Date;
  modifiedTime?: Date;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  type = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = Astro.site ?? new URL(identity.url);
const canonicalUrl = new URL(canonicalPath, siteUrl);
const russianUrl = new URL(swapLanguage(canonicalPath, 'ru'), siteUrl);
const englishUrl = new URL(swapLanguage(canonicalPath, 'en'), siteUrl);
const isAboutPage = canonicalPath === `/${lang}/about/`;
const isHomePage = canonicalPath === `/${lang}/`;
const documentTitle = isHomePage ? title : `${title} — ${identity.name[lang]}`;
const structuredData = createIdentityJsonLd(lang, isAboutPage);
---

<title>{documentTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="ru" href={russianUrl} />
<link rel="alternate" hreflang="en" href={englishUrl} />
<link rel="alternate" hreflang="x-default" href={russianUrl} />

<meta property="og:type" content={type} />
<meta property="og:title" content={documentTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={identity.name.en} />
<meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />
<meta property="og:locale:alternate" content={lang === 'ru' ? 'en_US' : 'ru_RU'} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
{type === 'profile' && <meta property="profile:first_name" content={identity.givenName} />}
{type === 'profile' && <meta property="profile:last_name" content={identity.familyName} />}

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={documentTitle} />
<meta name="twitter:description" content={description} />

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
