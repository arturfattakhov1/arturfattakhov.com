---
import type { PublicationRecord } from '../data/publication-records';
import { publicationPath } from '../data/publication-records';
import { publicationsPageCopy } from '../data/publications';
import type { Language } from '../i18n/config';
import PublicationBadges from './PublicationBadges.astro';

interface Props {
  record: PublicationRecord;
  lang: Language;
}

const { record, lang } = Astro.props;
const copy = publicationsPageCopy[lang];
---

<article class="publication-card">
  <div class="publication-card__main">
    <p class="publication-record-meta">
      <span>{copy.typeLabels[record.type]}</span>
      <span>{record.year}</span>
    </p>
    <h3>
      <a href={publicationPath(lang, record.slug)}>{record.title[lang]}</a>
    </h3>
    <p>{record.researchArea[lang]}</p>
    <p class="publication-card__venue">{record.venue}</p>
    <p class="entry-authors">{record.authors.join(', ')}</p>
  </div>
  <div class="publication-card__aside">
    <PublicationBadges record={record} lang={lang} />
    <a class="text-link" href={publicationPath(lang, record.slug)}>
      {copy.readRecord}<span aria-hidden="true"> →</span>
    </a>
  </div>
</article>
