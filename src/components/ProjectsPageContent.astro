---
import type { CollectionEntry } from 'astro:content';
import { projectsPageCopy } from '../data/remaining-pages';
import type { Language } from '../i18n/config';
import Card from './Card.astro';
import CollectionPlaceholder from './CollectionPlaceholder.astro';
import Container from './Container.astro';
import ProjectsSections from './ProjectsSections.astro';

interface Props {
  lang: Language;
  entries: CollectionEntry<'projects'>[];
}

const { lang, entries } = Astro.props;
const copy = projectsPageCopy[lang];
---

<ProjectsSections lang={lang}>
  <Fragment slot="hero">
    <Container class="section-copy section-copy--lead"><p>{copy.hero}</p></Container>
  </Fragment>

  <Fragment slot="focus">
    <Container class="section-copy"><p>{copy.focus}</p></Container>
  </Fragment>

  <Fragment slot="projects">
    <Container>
      {entries.length > 0 ? (
        <ol class="entry-list project-list">
          {entries.map((entry) => (
            <li>
              <article>
                <p class="entry-meta">{entry.data.startYear} — {copy.statusLabels[entry.data.status]}</p>
                <h3>
                  {entry.data.url ? (
                    <a href={entry.data.url} target="_blank" rel="noopener noreferrer">{entry.data.title}</a>
                  ) : entry.data.title}
                </h3>
                <p>{entry.data.description}</p>
              </article>
            </li>
          ))}
        </ol>
      ) : (
        <CollectionPlaceholder collection="projects" title={copy.placeholder.title} description={copy.placeholder.description} />
      )}
    </Container>
  </Fragment>

  <Fragment slot="future">
    <Container>
      <ul class="card-grid card-grid--three" role="list">
        {copy.futureStructure.map((item) => <li><Card {...item} /></li>)}
      </ul>
    </Container>
  </Fragment>
</ProjectsSections>
