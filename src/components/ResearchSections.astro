---
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const headings = {
  ru: ['Темы', 'Методы', 'Проверенные результаты', 'Связанные публикации', 'Профессиональное значение'],
  en: ['Topics', 'Methods', 'Verified outputs', 'Related publications', 'Professional relevance'],
} as const;
const ids = ['research-topics', 'research-methods', 'verified-results', 'related-publications', 'professional-relevance'] as const;
---
<div class="section-stack research-sections research-sections--compact">
  <PageIntro><slot name="opening" /></PageIntro>
  {ids.map((id, index) => <PageSection id={id} title={headings[lang][index]} density="editorial"><slot name={id} /></PageSection>)}
</div>
