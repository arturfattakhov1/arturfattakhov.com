---
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const headings = {
  ru: {
    project: 'Единственный проект',
    development: 'Что существует сейчас',
    principles: 'Предполагаемые принципы',
    position: 'Текущая позиция',
  },
  en: {
    project: 'The single project',
    development: 'What currently exists',
    principles: 'Intended principles',
    position: 'Current position',
  },
} as const satisfies Record<Language, Record<string, string>>;
const copy = headings[lang];
---

<div class="section-stack projects-sections projects-sections--v2">
  <PageIntro><slot name="hero" /></PageIntro>
  <PageSection id="project-profile" title={copy.project}><slot name="project" /></PageSection>
  <PageSection id="project-development" title={copy.development}><slot name="development" /></PageSection>
  <PageSection id="project-principles" title={copy.principles}><slot name="principles" /></PageSection>
  <PageSection id="project-position" title={copy.position}><slot name="position" /></PageSection>
</div>
