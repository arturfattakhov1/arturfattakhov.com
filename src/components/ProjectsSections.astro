---
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const headings = {
  ru: { focus: 'Направление', projects: 'Карточки проектов', future: 'Будущая структура' },
  en: { focus: 'Focus', projects: 'Project cards', future: 'Future structure' },
} as const satisfies Record<Language, Record<string, string>>;
const copy = headings[lang];
---

<div class="section-stack projects-sections">
  <PageIntro><slot name="hero" /></PageIntro>
  <PageSection id="project-focus" title={copy.focus}><slot name="focus" /></PageSection>
  <PageSection id="project-cards" title={copy.projects}><slot name="projects" /></PageSection>
  <PageSection id="future-project-structure" title={copy.future}><slot name="future" /></PageSection>
</div>
