---
import type { Language } from '../i18n/config';
import { mediaPageCopy } from '../data/media';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = mediaPageCopy[lang];
---
<div class="section-stack media-sections media-sections--professional">
  <PageIntro><slot name="opening" /></PageIntro>
  <PageSection id="interviews-and-comments" title={copy.sections.interviews} density="editorial"><slot name="interviews" /></PageSection>
  <PageSection id="interdisciplinary-projects" title={copy.sections.projects} density="editorial"><slot name="projects" /></PageSection>
  <PageSection id="authored-media" title={copy.sections.authored} density="editorial"><slot name="authored" /></PageSection>
</div>
