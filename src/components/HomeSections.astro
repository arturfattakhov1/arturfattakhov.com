---
import type { Language } from '../i18n/config';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
  helpTitle: string;
}

const { lang, helpTitle } = Astro.props;

const headings = {
  ru: {
    profile: 'Профессиональный профиль',
    materials: 'Новые материалы',
  },
  en: {
    profile: 'Professional profile',
    materials: 'New material',
  },
} as const satisfies Record<Language, Record<string, string>>;

const copy = headings[lang];
---

<div class="home-sections home-sections--slice-2">
  <section class="home-opening" aria-labelledby="page-title">
    <slot name="hero" />
  </section>
  <PageSection id="help" title={helpTitle} class="home-help" density="editorial">
    <slot name="help" />
  </PageSection>
  <PageSection id="professional-profile" title={copy.profile} class="home-profile" density="editorial">
    <slot name="profile" />
  </PageSection>
  <PageSection id="new-material" title={copy.materials} class="home-materials" density="editorial">
    <slot name="materials" />
  </PageSection>
</div>
