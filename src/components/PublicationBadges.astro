---
import type { PublicationRecord } from '../data/publication-records';
import { publicationsPageCopy } from '../data/publications';
import type { Language } from '../i18n/config';

interface Props {
  record: PublicationRecord;
  lang: Language;
}

const { record, lang } = Astro.props;
const copy = publicationsPageCopy[lang];
const badges = [
  record.doi ? `DOI ${record.doi}` : undefined,
  record.edn ? `EDN ${record.edn}` : undefined,
  record.patentNumber ? `${copy.typeLabels.patent} ${record.patentNumber}` : undefined,
].filter((badge) => badge !== undefined);
---

{badges.length > 0 && (
  <ul class="publication-badges" role="list" aria-label={lang === 'ru' ? 'Идентификаторы записи' : 'Record identifiers'}>
    {badges.map((badge) => <li>{badge}</li>)}
  </ul>
)}

<style>
  .publication-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .publication-badges li {
    padding: 0.25rem 0.55rem;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 650;
    letter-spacing: 0.02em;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    overflow-wrap: anywhere;
  }
</style>
