---
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const headings = {
  ru: {
    education: 'Образование',
    experience: 'Профессиональный опыт',
    research: 'Исследовательский опыт',
    qualifications: 'Квалификации и дополнительное обучение',
    output: 'Научные результаты',
    competencies: 'Профессиональные компетенции',
    languages: 'Языки',
    profiles: 'Профессиональные профили',
  },
  en: {
    education: 'Education',
    experience: 'Professional Experience',
    research: 'Research Experience',
    qualifications: 'Professional Qualifications and Continuing Education',
    output: 'Research Output Summary',
    competencies: 'Professional Competencies',
    languages: 'Languages',
    profiles: 'Professional Profiles',
  },
} as const satisfies Record<Language, Record<string, string>>;
const copy = headings[lang];
---

<div class="section-stack cv-sections cv-sections--v2">
  <PageIntro><slot name="hero" /></PageIntro>
  <PageSection id="cv-education" title={copy.education} density="editorial"><slot name="education" /></PageSection>
  <PageSection id="professional-experience" title={copy.experience} density="editorial"><slot name="experience" /></PageSection>
  <PageSection id="research-experience" title={copy.research} density="editorial"><slot name="research" /></PageSection>
  <PageSection id="professional-qualifications" title={copy.qualifications} density="editorial"><slot name="qualifications" /></PageSection>
  <PageSection id="research-output-summary" title={copy.output} density="editorial"><slot name="output" /></PageSection>
  <PageSection id="professional-competencies" title={copy.competencies} density="editorial"><slot name="competencies" /></PageSection>
  <PageSection id="cv-languages" title={copy.languages} density="editorial"><slot name="languages" /></PageSection>
  <PageSection id="cv-profiles" title={copy.profiles} density="editorial"><slot name="profiles" /></PageSection>
</div>
