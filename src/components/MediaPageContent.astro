---
import { mediaPageCopy, mediaRecords } from '../data/media';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Button from './Button.astro';
import Container from './Container.astro';
import MediaSections from './MediaSections.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = mediaPageCopy[lang];
const interviews = mediaRecords.filter((record) => record.type === 'interview');
const projects = mediaRecords.filter((record) => record.type === 'project');
const authored = mediaRecords.filter((record) => ['video', 'article', 'podcast'].includes(record.type));
---
<MediaSections lang={lang}>
  <Fragment slot="opening"><Container size="reading" class="media-professional-intro"><p>{copy.opening}</p><Button href={localizedPath(lang, 'contact')} variant="secondary">{copy.inquiry}</Button></Container></Fragment>
  <Fragment slot="interviews">
    <Container size="reading">
      {interviews.map((record) => (
        <article class="media-compact-card">
          <p>{copy.typeLabels[record.type]}</p>
          <h3>{record.title[lang]}</h3>
          <span>{record.summary[lang]}</span>
          <a class="text-link" href={record.externalLinks[0].url} target="_blank" rel="noopener noreferrer">{copy.actions[record.type]}<span aria-hidden="true"> ↗</span></a>
        </article>
      ))}
    </Container>
  </Fragment>
  <Fragment slot="projects">
    <Container size="reading">
      {projects.map((record) => (
        <article class="media-compact-card media-project-card">
          <p>{copy.typeLabels[record.type]}</p>
          <h3>{record.title[lang]}</h3>
          <span>{record.summary[lang]}</span>
          {record.role && <strong>{record.role[lang]}</strong>}
          <nav aria-label={copy.projectLinksLabel}>
            <ul>{record.externalLinks.map((link) => <li><a href={link.url} target="_blank" rel="noopener noreferrer">{link.source[lang]}<span aria-hidden="true"> ↗</span></a></li>)}</ul>
          </nav>
        </article>
      ))}
    </Container>
  </Fragment>
  <Fragment slot="authored">
    <Container>
      <ul class="media-channel-grid" role="list">
        {authored.map((record) => (
          <li>
            <article>
              <p>{copy.typeLabels[record.type]}</p>
              <h3>{record.title[lang]}</h3>
              <span>{record.summary[lang]}</span>
              <a class="text-link" href={record.externalLinks[0].url} target="_blank" rel="me noopener noreferrer">{copy.actions[record.type]}<span aria-hidden="true"> ↗</span></a>
            </article>
          </li>
        ))}
      </ul>
    </Container>
  </Fragment>
</MediaSections>
