---
import { mediaLinks, mediaPageCopy, mediaRecords } from '../data/media';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Button from './Button.astro';
import Container from './Container.astro';
import MediaSections from './MediaSections.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = mediaPageCopy[lang];
---
<MediaSections lang={lang}>
  <Fragment slot="opening"><Container size="reading" class="media-professional-intro"><p>{copy.opening}</p><Button href={localizedPath(lang, 'contact')} variant="secondary">{copy.inquiry}</Button></Container></Fragment>
  <Fragment slot="interviews"><Container size="reading"><article class="media-compact-card"><p>{copy.interview.label}</p><h3>{copy.interview.title}</h3><span>{copy.interview.description}</span><a class="text-link" href={mediaRecords.interview} target="_blank" rel="noopener noreferrer">{copy.interview.action}<span aria-hidden="true"> ↗</span></a></article></Container></Fragment>
  <Fragment slot="projects"><Container size="reading"><article class="media-compact-card media-project-card"><p>{copy.project.label}</p><h3>{copy.project.title}</h3><span>{copy.project.description}</span><strong>{copy.project.role}</strong><nav aria-label={copy.project.linksLabel}><ul>{mediaRecords.project.map((url, index) => <li><a href={url} target="_blank" rel="noopener noreferrer">{copy.project.links[index]}<span aria-hidden="true"> ↗</span></a></li>)}</ul></nav></article></Container></Fragment>
  <Fragment slot="authored"><Container><ul class="media-channel-grid" role="list">{copy.channels.map((channel) => <li><article><p>{channel.label}</p><h3>{channel.title}</h3><span>{channel.description}</span><a class="text-link" href={mediaLinks[channel.key]} target="_blank" rel="me noopener noreferrer">{channel.action}<span aria-hidden="true"> ↗</span></a></article></li>)}</ul></Container></Fragment>
</MediaSections>
