---
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const headings = {
  ru: {
    research: 'Научные профили и идентификаторы',
    professional: 'Профессиональные профили',
    public: 'Публичные профили',
    future: 'Проверка новых профилей',
  },
  en: {
    research: 'Research profiles and identifiers',
    professional: 'Professional profiles',
    public: 'Public profiles',
    future: 'Verification of new profiles',
  },
} as const satisfies Record<Language, Record<string, string>>;

const copy = headings[lang];
---

<div class="section-stack profiles-sections">
  <PageIntro><slot name="hero" /></PageIntro>
  <PageSection id="research-identifiers" title={copy.research}><slot name="research" /></PageSection>
  <PageSection id="professional-profiles" title={copy.professional}><slot name="professional" /></PageSection>
  <PageSection id="public-profiles" title={copy.public}><slot name="public" /></PageSection>
  <PageSection id="future-profiles" title={copy.future}><slot name="future" /></PageSection>
</div>
