---
import type { Language } from '../i18n/config';
import { profilesPageCopy } from '../data/profiles';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = profilesPageCopy[lang];
---

<div class="section-stack profiles-sections profiles-sections--v2">
  <PageIntro class="profiles-opening"><slot name="opening" /></PageIntro>
  <PageSection id="research-identity" title={copy.groups.research.title}><slot name="research" /></PageSection>
  <PageSection id="professional-presence" title={copy.groups.professional.title}><slot name="professional" /></PageSection>
  <PageSection id="publishing-channels" title={copy.groups.publishing.title}><slot name="publishing" /></PageSection>
  <PageSection id="profile-verification" title={copy.verification.title}><slot name="verification" /></PageSection>
</div>
