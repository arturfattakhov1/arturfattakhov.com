---
import { profilesPageCopy } from '../data/profiles';
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';
interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = profilesPageCopy[lang];
---
<div class="section-stack profiles-sections profiles-sections--compact">
  <PageIntro><slot name="opening" /></PageIntro>
  <PageSection id="profiles-scientific" title={copy.groups.scientific.title} density="compact"><slot name="scientific" /></PageSection>
  <PageSection id="profiles-media" title={copy.groups.media.title} density="compact"><slot name="media" /></PageSection>
  <PageSection id="profiles-social" title={copy.groups.social.title} density="compact"><slot name="social" /></PageSection>
  <PageSection id="profiles-technical" title={copy.groups.technical.title} density="compact"><slot name="technical" /></PageSection>
</div>
