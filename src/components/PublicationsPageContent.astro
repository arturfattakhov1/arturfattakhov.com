---
import { identity } from '../data/identity';
import { publicationsPageCopy } from '../data/publications';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Button from './Button.astro';
import Container from './Container.astro';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';
import ProfileCard from './ProfileCard.astro';
import PublicationPortfolio from './PublicationPortfolio.astro';

type ProfileKey = (typeof identity.profiles)[number]['key'];

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = publicationsPageCopy[lang];
const profilesByKey = new Map(identity.profiles.map((profile) => [profile.key, profile] as const));
const identifierKeys: ProfileKey[] = ['googleScholar', 'orcid', 'researchGate', 'webOfScience'];
const identifierProfiles = identifierKeys
  .map((key) => profilesByKey.get(key))
  .filter((profile) => profile !== undefined);
---

<div class="section-stack publications-sections">
  <PageIntro>
    <Container class="section-copy section-copy--lead">
      <p>{copy.hero}</p>
    </Container>
  </PageIntro>

  <PublicationPortfolio lang={lang} />

  <PageSection id="publication-identifiers" title={copy.identifiersTitle}>
    <Container>
      <ul class="card-grid" role="list">
        {identifierProfiles.map((profile) => (
          <li>
            <ProfileCard
              profile={profile}
              linkLabel={copy.profileLinkLabel}
              externalLinkLabel={copy.externalLinkLabel}
            />
          </li>
        ))}
      </ul>
      <div class="button-group">
        <Button href={localizedPath(lang, 'research')}>{copy.relatedLinks.research}</Button>
        <Button href={localizedPath(lang, 'profiles')} variant="secondary">{copy.relatedLinks.profiles}</Button>
        <Button href={localizedPath(lang, 'about')} variant="secondary">{lang === 'ru' ? 'Об авторе' : 'About the author'}</Button>
      </div>
    </Container>
  </PageSection>
</div>
