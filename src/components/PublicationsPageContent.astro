---
import { publicationPath, publicationRecords } from '../data/publication-records';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Container from './Container.astro';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const counts = {
  total: publicationRecords.length,
  journal: publicationRecords.filter((record) => record.type === 'journal').length,
  conference: publicationRecords.filter((record) => record.type === 'conference').length,
  patent: publicationRecords.filter((record) => record.type === 'patent').length,
};
const years = [...new Set(publicationRecords.map((record) => record.year))].sort((a, b) => b - a);
const copy = {
  ru: {
    lead: 'Компактный архив проверенных журнальных статей, материалов конференций и патента.',
    countLabels: { total: 'Всего записей', journal: 'Журнальные статьи', conference: 'Материалы конференций', patent: 'Патент' },
    archive: 'Архив по годам', types: { journal: 'Журнальная статья', conference: 'Материалы конференции', patent: 'Патент' },
    authors: 'Авторы', source: 'Источник', action: 'Открыть запись', related: 'Исследовательский контекст',
  },
  en: {
    lead: 'A compact archive of verified journal articles, conference proceedings, and a patent.',
    countLabels: { total: 'Total records', journal: 'Journal articles', conference: 'Conference proceedings', patent: 'Patent' },
    archive: 'Archive by year', types: { journal: 'Journal article', conference: 'Conference proceeding', patent: 'Patent' },
    authors: 'Authors', source: 'Source', action: 'Open record', related: 'Research context',
  },
} as const;
const text = copy[lang];
---

<div class="section-stack publications-compact" data-publication-archive data-record-count={counts.total} data-journal-count={counts.journal} data-conference-count={counts.conference} data-patent-count={counts.patent}>
  <PageIntro>
    <Container size="reading"><p class="publication-archive-lead">{text.lead}</p><dl class="publication-counts">{Object.entries(counts).map(([key, value]) => <div><dt>{text.countLabels[key as keyof typeof text.countLabels]}</dt><dd>{value}</dd></div>)}</dl></Container>
  </PageIntro>
  <PageSection id="publication-archive" title={text.archive} density="compact">
    <Container>
      <div class="publication-year-groups">
        {years.map((year) => (
          <section aria-labelledby={`publication-year-${year}`} data-publication-year={year}>
            <h3 id={`publication-year-${year}`}>{year}</h3>
            <ol>
              {publicationRecords.filter((record) => record.year === year).map((record) => (
                <li data-publication-record={record.slug} data-publication-type={record.type}>
                  <article class="publication-compact-record">
                    <p class="publication-compact-record__type">{text.types[record.type]}</p>
                    <h4><a href={publicationPath(lang, record.slug)}>{record.title[lang]}</a></h4>
                    <dl>
                      <div><dt>{text.authors}</dt><dd>{record.authors.join(', ')}</dd></div>
                      <div><dt>{text.source}</dt><dd>{record.venue}</dd></div>
                    </dl>
                    <ul class="publication-identifiers" role="list">
                      {record.doi && <li>DOI {record.doi}</li>}
                      {record.edn && <li>EDN {record.edn}</li>}
                      {record.patentNumber && <li>{record.patentNumber}</li>}
                      {record.applicationNumber && <li>{lang === 'ru' ? 'Заявка' : 'Application'} {record.applicationNumber}</li>}
                    </ul>
                    <a class="text-link" href={publicationPath(lang, record.slug)}>{text.action}<span aria-hidden="true"> →</span></a>
                  </article>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
      <a class="text-link publication-related-link" href={localizedPath(lang, 'research')}>{text.related}<span aria-hidden="true"> →</span></a>
    </Container>
  </PageSection>
</div>
