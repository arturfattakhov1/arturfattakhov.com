---
import type { Language } from '../i18n/config';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const headings = {
  ru: {
    hero: 'Публикации',
    scientific: 'Научные публикации',
    professional: 'Профессиональные статьи',
    identifiers: 'Google Scholar и идентификаторы',
    future: 'Будущая структура',
  },
  en: {
    hero: 'Publications',
    scientific: 'Scientific publications',
    professional: 'Professional articles',
    identifiers: 'Google Scholar and identifiers',
    future: 'Future structure',
  },
} as const satisfies Record<Language, Record<string, string>>;

const copy = headings[lang];
---

<div class="publications-sections">
  <PageSection id="publications-overview" title={copy.hero}><slot name="hero" /></PageSection>
  <PageSection id="scientific-publications" title={copy.scientific}><slot name="scientific" /></PageSection>
  <PageSection id="professional-articles" title={copy.professional}><slot name="professional" /></PageSection>
  <PageSection id="publication-identifiers" title={copy.identifiers}><slot name="identifiers" /></PageSection>
  <PageSection id="future-publication-structure" title={copy.future}><slot name="future" /></PageSection>
</div>
