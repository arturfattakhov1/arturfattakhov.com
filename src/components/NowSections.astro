---
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const headings = {
  ru: { website: 'Личный сайт', homeCare: 'Ветеринарная помощь на дому', research: 'Исследования', ai: 'ИИ в ветеринарной медицине' },
  en: { website: 'Personal website', homeCare: 'Home veterinary care', research: 'Research', ai: 'AI in veterinary medicine' },
} as const satisfies Record<Language, Record<string, string>>;
const copy = headings[lang];
---

<div class="section-stack now-sections">
  <PageIntro><slot name="hero" /></PageIntro>
  <PageSection id="personal-website" title={copy.website}><slot name="website" /></PageSection>
  <PageSection id="home-veterinary-care" title={copy.homeCare}><slot name="home-care" /></PageSection>
  <PageSection id="now-research" title={copy.research}><slot name="research" /></PageSection>
  <PageSection id="ai-in-veterinary-medicine" title={copy.ai}><slot name="ai" /></PageSection>
</div>
