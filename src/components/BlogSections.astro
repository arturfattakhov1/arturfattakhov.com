---
import { blogPageCopy } from '../data/blog';
import type { Language } from '../i18n/config';
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const copy = blogPageCopy[lang];
---

<div class="section-stack blog-sections">
  <PageIntro><slot name="hero" /></PageIntro>
  <PageSection id="blog-articles" title={copy.sectionTitle}><slot name="articles" /></PageSection>
</div>
