---
import { contactEmail, contactPageCopy } from '../data/contact';
import { identity } from '../data/identity';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Button from './Button.astro';
import Card from './Card.astro';
import ContactSections from './ContactSections.astro';
import Container from './Container.astro';
import KnowledgeHubNavigation from './KnowledgeHubNavigation.astro';
import ProfileCard from './ProfileCard.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = contactPageCopy[lang];
---

<ContactSections lang={lang}>
  <Fragment slot="hero">
    <Container class="section-copy section-copy--lead">
      <p>{copy.hero}</p>
    </Container>
  </Fragment>

  <Fragment slot="email">
    <Container>
      <address class="contact-email-block">
        <p>{copy.emailDescription}</p>
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </address>
    </Container>
  </Fragment>

  <Fragment slot="inquiries">
    <Container>
      <ul class="card-grid" role="list">
        {copy.inquiryTypes.map((item) => <li><Card {...item} /></li>)}
      </ul>
      <div class="button-group">
        <Button href={localizedPath(lang, 'profiles')} variant="secondary">
          {copy.profilesCta}
        </Button>
      </div>
    </Container>
  </Fragment>

  <Fragment slot="profiles">
    <Container>
      <ul class="card-grid card-grid--profiles" role="list">
        {identity.profiles.map((profile) => (
          <li>
            <ProfileCard
              profile={profile}
              linkLabel={copy.profileLinkLabel}
              externalLinkLabel={copy.externalLinkLabel}
            />
          </li>
        ))}
      </ul>
    </Container>
  </Fragment>

  <Fragment slot="response">
    <Container class="section-copy">
      <p>{copy.responseNote}</p>
      <KnowledgeHubNavigation lang={lang} />
    </Container>
  </Fragment>
</ContactSections>
