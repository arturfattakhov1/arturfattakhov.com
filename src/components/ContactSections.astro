---
import PageIntro from './PageIntro.astro';
import PageSection from './PageSection.astro';

interface Props {
  formTitle: string;
}

const { formTitle } = Astro.props;
---

<div class="section-stack contact-sections contact-sections--v2">
  <PageIntro class="contact-opening"><slot name="hero" /></PageIntro>
  <PageSection id="contact-form" title={formTitle} class="contact-form-section">
    <slot name="form" />
  </PageSection>
</div>
