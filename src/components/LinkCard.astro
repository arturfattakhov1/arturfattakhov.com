---
import Card from './Card.astro';

interface Props {
  title: string;
  description?: string;
  href: string;
  linkLabel: string;
}

const { title, description, href, linkLabel } = Astro.props;
---

<Card title={title} description={description}>
  <a class="card-link" href={href}>
    {linkLabel}<span aria-hidden="true"> →</span>
  </a>
</Card>
