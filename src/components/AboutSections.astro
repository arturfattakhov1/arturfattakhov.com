---
import type { Language } from '../i18n/config';
import PageSection from './PageSection.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const headings = {
  ru: {
    opening: 'Профессиональная позиция',
    system: 'Единая профессиональная система',
    education: 'Образование и развитие',
    research: 'Исследовательский путь',
    principles: 'Принципы работы',
    direction: 'Текущее направление',
  },
  en: {
    opening: 'Professional position',
    system: 'One professional system',
    education: 'Education and development',
    research: 'Research path',
    principles: 'Professional principles',
    direction: 'Current direction',
  },
} as const satisfies Record<Language, Record<string, string>>;

const copy = headings[lang];
---

<div class="section-stack about-sections about-sections--v2">
  <PageSection id="professional-position" title={copy.opening} density="open"><slot name="opening" /></PageSection>
  <PageSection id="professional-system" title={copy.system}><slot name="system" /></PageSection>
  <PageSection id="education-and-development" title={copy.education}><slot name="education" /></PageSection>
  <PageSection id="research-path" title={copy.research}><slot name="research" /></PageSection>
  <PageSection id="professional-principles" title={copy.principles}><slot name="principles" /></PageSection>
  <PageSection id="current-direction" title={copy.direction} density="open"><slot name="direction" /></PageSection>
</div>
