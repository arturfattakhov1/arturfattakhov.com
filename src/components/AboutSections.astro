---
import type { Language } from '../i18n/config';
import PageSection from './PageSection.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const headings = {
  ru: ['Кратко обо мне', 'Почему ветеринарная медицина', 'Клиническая практика', 'Визуальная диагностика', 'Предпринимательский опыт', 'Исследовательская квалификация', 'Профессиональное видение', 'Профессиональная хронология'],
  en: ['Professional introduction', 'Why veterinary medicine', 'Clinical practice', 'Diagnostic imaging', 'Entrepreneurial experience', 'Research qualification', 'Professional vision', 'Professional timeline'],
} as const;
const ids = ['introduction', 'why-veterinary-medicine', 'clinical-practice', 'diagnostic-imaging', 'entrepreneurial-experience', 'research-qualification', 'professional-vision', 'professional-timeline'] as const;
---

<div class="section-stack about-sections about-sections--professional">
  {ids.map((id, index) => (
    <PageSection id={id} title={headings[lang][index]} density={index === 0 || index === 6 ? 'open' : 'editorial'}>
      <slot name={id} />
    </PageSection>
  ))}
</div>
