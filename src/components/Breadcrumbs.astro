---
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import { ui } from '../i18n/ui';
import { createBreadcrumbJsonLd } from '../data/structured-data';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  lang: Language;
  items: BreadcrumbItem[];
}

const { lang, items } = Astro.props;
const structuredData = createBreadcrumbJsonLd(lang, Astro.url.pathname, items);
---

<nav class="breadcrumbs" aria-label={lang === 'ru' ? 'Хлебные крошки' : 'Breadcrumbs'}>
  <ol>
    <li><a href={localizedPath(lang)}>{ui[lang].home}</a></li>
    {items.map((item) => (
      <li>
        {item.href ? <a href={item.href}>{item.label}</a> : <span aria-current="page">{item.label}</span>}
      </li>
    ))}
  </ol>
</nav>

<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
