---
import { researchPageCopy } from '../data/research';
import { publicationRecords } from '../data/publication-records';
import { identity } from '../data/identity';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Button from './Button.astro';
import Card from './Card.astro';
import Container from './Container.astro';
import KnowledgeHubNavigation from './KnowledgeHubNavigation.astro';
import LinkCard from './LinkCard.astro';
import ProfileCard from './ProfileCard.astro';
import PublicationCard from './PublicationCard.astro';
import ResearchSections from './ResearchSections.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = researchPageCopy[lang];
type ProfileKey = (typeof identity.profiles)[number]['key'];
const profilesByKey = new Map(identity.profiles.map((profile) => [profile.key, profile] as const));
const profileKeys: ProfileKey[] = ['orcid', 'googleScholar', 'researchGate', 'webOfScience'];
const academicProfiles = profileKeys
  .map((key) => profilesByKey.get(key))
  .filter((profile) => profile !== undefined);
const patent = publicationRecords.find((record) => record.type === 'patent');
---

<ResearchSections lang={lang}>
  <Fragment slot="hero">
    <Container class="about-copy about-copy--lead">
      {copy.hero.map((paragraph) => <p>{paragraph}</p>)}
    </Container>
  </Fragment>

  <Fragment slot="interests">
    <Container>
      <ul class="card-grid card-grid--three" role="list">
        {copy.interests.map((item) => <li><Card {...item} /></li>)}
      </ul>
    </Container>
  </Fragment>

  <Fragment slot="current-research">
    <Container class="about-copy">
      {copy.currentResearch.map((paragraph) => <p>{paragraph}</p>)}
      <div class="button-group">
        <Button href={localizedPath(lang, 'publications')}>{copy.relatedLinks.publications}</Button>
        <Button href={localizedPath(lang, 'profiles')} variant="secondary">{copy.relatedLinks.profiles}</Button>
      </div>
    </Container>
  </Fragment>

  <Fragment slot="publications">
    <Container>
      <LinkCard
        title={copy.publications.title}
        description={copy.publications.description}
        href={localizedPath(lang, 'publications')}
        linkLabel={copy.relatedLinks.publications}
      />
    </Container>
  </Fragment>

  <Fragment slot="patents">
    <Container>
      {patent && <PublicationCard record={patent} lang={lang} />}
    </Container>
  </Fragment>

  <Fragment slot="profiles">
    <Container>
      <ul class="card-grid" role="list">
        {academicProfiles.map((profile) => (
          <li>
            <ProfileCard
              profile={profile}
              linkLabel={copy.profileLinkLabel}
              externalLinkLabel={copy.externalLinkLabel}
            />
          </li>
        ))}
      </ul>
    </Container>
  </Fragment>

  <Fragment slot="future-directions">
    <Container class="about-copy">
      {copy.futureDirections.map((paragraph) => <p>{paragraph}</p>)}
      <KnowledgeHubNavigation lang={lang} />
    </Container>
  </Fragment>
</ResearchSections>
