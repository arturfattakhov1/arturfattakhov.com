---
import { publicationPath, publicationRecords } from '../data/publication-records';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import Button from './Button.astro';
import Container from './Container.astro';
import ResearchSections from './ResearchSections.astro';

interface Props { lang: Language; }
const { lang } = Astro.props;
const relatedSlugs = ['comparative-xray-morphometry-moose-cattle', 'hoof-capsule-cattle-moose', 'xray-morphometric-laminitis-cattle-patent'];
const related = publicationRecords.filter((record) => relatedSlugs.includes(record.slug));
const copy = {
  ru: {
    opening: 'Я рассматриваю исследования как способ точнее формулировать вопросы, описывать методы и отделять проверенные данные от предположений.',
    topics: [
      ['Сравнительная анатомия', 'Сопоставление анатомических структур у разных видов животных.'],
      ['Ветеринарная морфология', 'Описание макро- и микроморфологических характеристик.'],
      ['Рентгеноморфометрия', 'Измерение и сопоставление структур по рентгенографическим данным.'],
      ['Диагностические темы', 'Связь визуальных методов с конкретным клиническим вопросом.'],
    ],
    methods: 'В подтверждённых работах использованы сравнительный анатомический анализ, микроморфологическое описание и рентгеноморфометрия. Детали не расширяются за пределы опубликованных записей.',
    outputs: 'Проверенный архив содержит 2 журнальные статьи, 6 публикаций в материалах конференций и 1 зарегистрированный патент.',
    publications: 'Ниже — записи, наиболее прямо связанные со сравнительной анатомией, морфологией и рентгеноморфометрией.',
    action: 'Открыть запись', all: 'Полный архив публикаций',
    relevance: 'Исследовательская подготовка помогает мне точнее оценивать методы, качество данных и границы интерпретации. В практической работе это поддерживает клиническое мышление, но не подменяет осмотр и диагностику конкретного пациента.',
  },
  en: {
    opening: 'I use research to frame questions more precisely, describe methods clearly, and separate verified evidence from assumptions.',
    topics: [
      ['Comparative anatomy', 'Comparison of anatomical structures across animal species.'],
      ['Veterinary morphology', 'Description of macro- and micromorphological characteristics.'],
      ['Radiomorphometry', 'Measurement and comparison of structures using radiographic evidence.'],
      ['Diagnostic topics', 'Connecting imaging methods with a specific clinical question.'],
    ],
    methods: 'The verified work uses comparative anatomical analysis, micromorphological description, and radiomorphometry. Details are not extended beyond the published records.',
    outputs: 'The verified archive contains 2 journal articles, 6 conference proceedings, and 1 registered patent.',
    publications: 'These records connect most directly with comparative anatomy, morphology, and radiomorphometry.',
    action: 'Open record', all: 'Complete publication archive',
    relevance: 'Research training helps me assess methods, evidence quality, and the limits of interpretation more precisely. In practice, it supports clinical reasoning but does not replace examination or diagnostics for an individual patient.',
  },
} as const;
const text = copy[lang];
---

<ResearchSections lang={lang}>
  <Fragment slot="opening"><Container size="reading" class="research-compact-opening"><p>{text.opening}</p><Button href={localizedPath(lang, 'publications')} variant="secondary">{text.all}</Button></Container></Fragment>
  <Fragment slot="research-topics"><Container size="reading"><dl class="research-topic-grid">{text.topics.map(([title, description]) => <div><dt>{title}</dt><dd>{description}</dd></div>)}</dl></Container></Fragment>
  <Fragment slot="research-methods"><Container size="reading"><p class="section-lead-compact">{text.methods}</p></Container></Fragment>
  <Fragment slot="verified-results"><Container size="reading"><p class="section-lead-compact" data-research-output-summary>{text.outputs}</p></Container></Fragment>
  <Fragment slot="related-publications">
    <Container size="reading"><p>{text.publications}</p><ol class="research-related-records">{related.map((record) => <li><span>{record.year} · {record.type === 'patent' ? (lang === 'ru' ? 'Патент' : 'Patent') : (lang === 'ru' ? 'Статья' : 'Article')}</span><h3><a href={publicationPath(lang, record.slug)}>{record.title[lang]}</a></h3><a class="text-link" href={publicationPath(lang, record.slug)}>{text.action}<span aria-hidden="true"> →</span></a></li>)}</ol><a class="text-link" href={localizedPath(lang, 'publications')}>{text.all}<span aria-hidden="true"> →</span></a></Container>
  </Fragment>
  <Fragment slot="professional-relevance"><Container size="reading"><p class="section-lead-compact">{text.relevance}</p></Container></Fragment>
</ResearchSections>
