---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageStructuredData from '../components/PageStructuredData.astro';
import type { PageSchemaType, SchemaListItem } from '../data/structured-data';
import type { Language } from '../i18n/config';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lang: Language;
  canonicalPath: string;
  showBreadcrumbs?: boolean;
  type?: 'profile' | 'article' | 'website';
  schemaType?: PageSchemaType;
  schemaItems?: SchemaListItem[];
  showVerifiedProfiles?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  showBreadcrumbs = true,
  type = 'website',
  schemaType,
  schemaItems,
  showVerifiedProfiles = true,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonicalPath={canonicalPath}
  type={type}
  showVerifiedProfiles={showVerifiedProfiles}
>
  {showBreadcrumbs && <Breadcrumbs lang={lang} items={[{ label: title }]} />}
  <article class:list={['page', { 'page--home': !showBreadcrumbs }]}>
    <header class="page-header">
      <h1 id="page-title">{title}</h1>
    </header>
    <div class="page-content">
      <slot />
    </div>
  </article>
  {schemaType && (
    <PageStructuredData
      type={schemaType}
      lang={lang}
      canonicalPath={canonicalPath}
      title={title}
      description={description}
      items={schemaItems}
    />
  )}
</BaseLayout>
