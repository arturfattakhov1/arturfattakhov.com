---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { Language } from '../i18n/config';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lang: Language;
  canonicalPath: string;
  showBreadcrumbs?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  showBreadcrumbs = true,
} = Astro.props;
---

<BaseLayout title={title} description={description} lang={lang} canonicalPath={canonicalPath} type={showBreadcrumbs ? 'website' : 'profile'}>
  {showBreadcrumbs && <Breadcrumbs lang={lang} items={[{ label: title }]} />}
  <article class:list={['page', { 'page--home': !showBreadcrumbs }]}>
    <header class="page-header">
      <h1 id="page-title">{title}</h1>
    </header>
    <div class="page-content">
      <slot />
    </div>
  </article>
</BaseLayout>
