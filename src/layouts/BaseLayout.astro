---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SEO from '../components/SEO.astro';
import type { Language } from '../i18n/config';

interface Props {
  title: string;
  description: string;
  lang: Language;
  canonicalPath: string;
  type?: 'profile' | 'article' | 'website';
  publishedTime?: Date;
  modifiedTime?: Date;
  showVerifiedProfiles?: boolean;
  searchable?: boolean;
  searchType?: string;
  alternatePaths?: Record<Language, string>;
  appendSiteName?: boolean;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  type,
  publishedTime,
  modifiedTime,
  showVerifiedProfiles = true,
  searchable = false,
  searchType,
  alternatePaths,
  appendSiteName = true,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f7f8f5" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <SEO
      title={title}
      description={description}
      lang={lang}
      canonicalPath={canonicalPath}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      alternatePaths={alternatePaths}
      appendSiteName={appendSiteName}
    />
    {searchable && searchType && (
      <meta name="page-type" content={searchType} data-pagefind-meta="type[content]" />
    )}
  </head>
  <body>
    <div class="site-shell">
      <Header lang={lang} currentPath={canonicalPath} />
      <main id="main-content" tabindex="-1" data-pagefind-body={searchable ? true : undefined}>
        <slot />
      </main>
      <Footer lang={lang} showVerifiedProfiles={showVerifiedProfiles} />
    </div>
    <script is:inline src="/scripts/navigation.js" defer></script>
  </body>
</html>
