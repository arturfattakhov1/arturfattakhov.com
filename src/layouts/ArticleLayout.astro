---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { Language } from '../i18n/config';
import { localizedPath } from '../i18n/config';
import { ui } from '../i18n/ui';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  lang: Language;
  canonicalPath: string;
  publishDate: Date;
  updatedDate?: Date;
}

const { title, description, lang, canonicalPath, publishDate, updatedDate } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat(lang === 'ru' ? 'ru-RU' : 'en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  canonicalPath={canonicalPath}
  type="article"
  publishedTime={publishDate}
  modifiedTime={updatedDate}
>
  <Breadcrumbs
    lang={lang}
    items={[
      { label: ui[lang].allPosts, href: localizedPath(lang, 'blog') },
      { label: title },
    ]}
  />
  <article class="article">
    <header class="article-header">
      <p class="eyebrow">{lang === 'ru' ? 'Статья' : 'Article'}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <p class="article-meta">
        {ui[lang].published}: <time datetime={publishDate.toISOString()}>{dateFormatter.format(publishDate)}</time>
        {updatedDate && <><span aria-hidden="true"> · </span>{ui[lang].updated}: <time datetime={updatedDate.toISOString()}>{dateFormatter.format(updatedDate)}</time></>}
      </p>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
